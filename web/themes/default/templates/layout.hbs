<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{#if title}}{{title}} — {{/if}}{{site_name}}</title>
  <meta name="description" content="{{meta_description}}">
  <script src="https://cdn.tailwindcss.com"></script>
  {{#if theme_css}}<style>{{theme_css}}</style>{{/if}}
  <style>
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll { animation: scroll 30s linear infinite; }
    .animate-scroll:hover { animation-play-state: paused; }
  </style>
</head>
<body class="bg-gray-50 font-sans antialiased">

  <!-- Top Bar -->
  <div class="bg-[#1d2129] text-white text-xs">
    <div class="max-w-6xl mx-auto px-4 h-8 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="hidden sm:inline">{{today}}</span>
        <div class="flex items-center gap-2">
          {{#if settings.social_facebook}}<a href="{{settings.social_facebook}}" target="_blank" class="hover:text-red-400" aria-label="Facebook"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>{{/if}}
          {{#if settings.social_instagram}}<a href="{{settings.social_instagram}}" target="_blank" class="hover:text-red-400" aria-label="Instagram"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>{{/if}}
          {{#if settings.social_twitter}}<a href="{{settings.social_twitter}}" target="_blank" class="hover:text-red-400" aria-label="Twitter"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>{{/if}}
          {{#if settings.social_youtube}}<a href="{{settings.social_youtube}}" target="_blank" class="hover:text-red-400" aria-label="YouTube"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>{{/if}}
        </div>
      </div>
      <div class="flex items-center gap-2"><span>28.7°C Kediri</span></div>
    </div>
  </div>

  <!-- Header -->
  <header class="bg-white border-b sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="text-2xl font-bold text-red-600 tracking-tight">{{site_name}}</a>
        <nav class="hidden lg:flex items-center gap-1">
          {{#each header_menu_items}}
          <div class="relative group">
            <a href="{{url}}" class="px-3 py-4 text-sm font-medium text-gray-800 hover:text-red-600 inline-flex items-center gap-1">{{label}}{{#if children}} <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>{{/if}}</a>
            {{#if children}}
            <div class="absolute top-full left-0 bg-white shadow-lg border rounded-md p-2 min-w-40 opacity-0 invisible group-hover:opacity-100 group-hover:visible z-50">
              {{#each children}}<a href="{{url}}" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-red-600 rounded">{{label}}</a>{{/each}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </nav>
        <div class="flex items-center gap-2">
          <a href="/search" class="p-2 text-gray-600 hover:text-red-600" aria-label="Search"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></a>
          <button class="lg:hidden p-2 text-gray-600 mobile-toggle" onclick="document.querySelector('.mobile-menu').classList.toggle('hidden')" aria-label="Menu"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg></button>
        </div>
      </div>
    </div>
    <div class="mobile-menu hidden lg:hidden border-t bg-white">
      <div class="max-w-6xl mx-auto px-4 py-4 space-y-1">
        {{#each header_menu_items}}
        {{#if children}}
        <details class="group">
          <summary class="flex items-center justify-between px-3 py-2 text-sm font-medium text-gray-800 rounded hover:bg-gray-50 cursor-pointer">{{label}} <svg class="h-3 w-3 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></summary>
          <div class="ml-4 mt-1 space-y-1">{{#each children}}<a href="{{url}}" class="block px-3 py-2 text-sm text-gray-600 hover:text-red-600 rounded hover:bg-gray-50">{{label}}</a>{{/each}}</div>
        </details>
        {{else}}<a href="{{url}}" class="block px-3 py-2 text-sm font-medium text-gray-800 rounded hover:bg-gray-50">{{label}}</a>{{/if}}
        {{/each}}
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="flex-1 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 py-6">
      {{{body}}}
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-[#1d2129] text-gray-400">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <a href="/" class="text-2xl font-bold text-white mb-4 block">{{site_name}}</a>
          <p class="text-sm leading-relaxed">{{site_name}} is a modern news CMS built with SvelteKit and Tailwind CSS.</p>
          <div class="flex items-center gap-3 mt-4">
            {{#if settings.social_facebook}}<a href="{{settings.social_facebook}}" target="_blank" class="hover:text-red-400" aria-label="Facebook"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>{{/if}}
            {{#if settings.social_instagram}}<a href="{{settings.social_instagram}}" target="_blank" class="hover:text-red-400" aria-label="Instagram"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>{{/if}}
            {{#if settings.social_twitter}}<a href="{{settings.social_twitter}}" target="_blank" class="hover:text-red-400" aria-label="Twitter"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>{{/if}}
            {{#if settings.social_youtube}}<a href="{{settings.social_youtube}}" target="_blank" class="hover:text-red-400" aria-label="YouTube"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>{{/if}}
          </div>
        </div>
        <div>
          <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Kategori</h4>
          <div class="space-y-2 text-sm">
            {{#each categories}}
            <a href="/kategori/{{slug}}" class="flex justify-between hover:text-white transition-colors"><span>{{name}}</span></a>
            {{/each}}
          </div>
        </div>
        <div>
          <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Link</h4>
          <div class="space-y-2 text-sm">
            <a href="/about" class="block hover:text-white">Tentang Kami</a>
            <a href="/contact" class="block hover:text-white">Kontak</a>
            <a href="/search" class="block hover:text-white">Pencarian</a>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-800">
      <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between text-xs">
        <p>© {{current_year}} {{site_name}} - All Rights Reserved</p>
      </div>
    </div>
  </footer>

  <script>
    document.querySelector('.mobile-toggle')?.addEventListener('click', function() {
      document.querySelector('.mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
